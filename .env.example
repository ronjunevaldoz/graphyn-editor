# Copy this file to .env or .env.local and fill in your values.
# .env, .env.local, and .env.*.local are all gitignored — never commit them.

# ── AI / Ollama ────────────────────────────────────────────────────────────────
# Ollama host for the desktop app's AI workflow generator.
# Default (when unset): http://localhost:11434
# Set this if your Ollama instance runs on a remote or non-standard host.
GRAPHYN_OLLAMA_HOST=http://localhost:11434

# ── Media plugins ──────────────────────────────────────────────────────────────
# External binary for text-to-speech. When unset, falls back to macOS `say`.
# GRAPHYN_TTS_EXECUTABLE=/usr/local/bin/my-tts

# External binary for speech-to-text. No zero-config fallback — required for
# the Captioned Video template to run.
# GRAPHYN_STT_EXECUTABLE=/usr/local/bin/whisper

# External binary for OCR. When unset, falls back to `tesseract` if available.
# GRAPHYN_OCR_EXECUTABLE=/usr/local/bin/tesseract

# ── Server ─────────────────────────────────────────────────────────────────────
# Bearer token to protect the Graphyn server API. Leave unset for open/dev access.
# GRAPHYN_API_KEY=change-me-before-deploying

# ── Doppler (secrets management) ───────────────────────────────────────────────
# Get your token from: Doppler dashboard → project → Access → Service Tokens
# DOPPLER_TOKEN=dp.st.xxxxxxxxxxxxxxxxxxxx
